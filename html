<!DOCTYPE html>
<html>
<head>
    <title>Weather Website</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            background: linear-gradient(skyblue, white);
            padding-top: 100px;
        }
        .box {
            background: white;
            width: 300px;
            margin: auto;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 0 10px gray;
        }
        input {
            padding: 10px;
            width: 200px;
        }
        button {
            padding: 10px;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<div class="box">
    <h1>🌤 Weather App</h1>
    <input type="text" id="city" placeholder="Enter city name">
    <br><br>
    <button onclick="getWeather()">Search</button>
    <h2 id="result"></h2>
</div>

<script>
function getWeather() {
    let city = document.getElementById("city").value;
    document.getElementById("result").innerHTML =
        "Weather in " + city + ": Sunny, 30°C";
}
</script>

</body>
</html>
